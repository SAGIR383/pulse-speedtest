# Pulse — environment variables (ALL OPTIONAL)
# ============================================
# The app works out of the box with NO environment variables.
# Everything below is optional tuning.

# Measurement backend:
#   cloudflare (default) → measures against speed.cloudflare.com's global
#                          network; closest to real ISP throughput (Ookla-like).
#   origin               → measures against this app's own API routes
#                          (reflects path to your hosting CDN edge).
# NEXT_PUBLIC_MEASUREMENT_BACKEND=cloudflare

# Point the measurement engine at a standalone telemetry server
# (the optional Express + WebSocket server in /server). Leave unset to use
# the built-in Next.js API routes on the same origin (recommended for
# Vercel / Cloudflare Pages).
# Example: https://pulse-telemetry.up.railway.app
# NEXT_PUBLIC_TELEMETRY_ORIGIN=

# Standalone server port (only used when running `npm run server`).
# PORT=8080
